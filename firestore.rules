rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: projectId (string)
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - ownerId: string (required, immutable)
    //   - createdAt: number (required, immutable)
    //   - updatedAt: number (required)
    //   - settings: map (required)
    //
    // Collection: projects/{projectId}/docs
    // Document ID: docId (string)
    // Fields:
    //   - id: string (required)
    //   - title: string (required, 0-200 chars)
    //   - content: string (required, 0-1MB)
    //   - type: string (required, enum)
    //   - parentId: string (optional)
    //   - order: number (required)
    //   - metadata: map (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "luksjfernandes@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProject(data) {
      return hasRequiredFields(['id', 'name', 'ownerId', 'createdAt', 'updatedAt', 'settings']) &&
             data.id is string &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.ownerId is string &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.settings is map;
    }

    function isValidDoc(data) {
      return hasRequiredFields(['id', 'title', 'content', 'type', 'order', 'metadata']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 1048576 && // 1MB
             data.type in ['text', 'folder', 'research', 'trash', 'front-matter', 'characters', 'places'] &&
             data.order is number &&
             data.metadata is map;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if isAuthenticated() && 
                      isValidProject(request.resource.data) && 
                      request.resource.data.ownerId == request.auth.uid;
                      
      allow update: if isAuthenticated() && 
                      isValidProject(request.resource.data) && 
                      (resource.data.ownerId == request.auth.uid || isAdmin()) &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
                      
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());

      match /docs/{docId} {
        allow read: if isAuthenticated() && (isProjectOwner(projectId) || isAdmin());
        
        allow create: if isAuthenticated() && 
                        isProjectOwner(projectId) && 
                        isValidDoc(request.resource.data);
                        
        allow update: if isAuthenticated() && 
                        isProjectOwner(projectId) && 
                        isValidDoc(request.resource.data);
                        
        allow delete: if isAuthenticated() && (isProjectOwner(projectId) || isAdmin());
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
