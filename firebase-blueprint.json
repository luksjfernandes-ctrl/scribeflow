{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A writing project containing settings and metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "settings": {
          "type": "object",
          "properties": {
            "targetWordCount": { "type": "number" },
            "sessionTarget": { "type": "number" },
            "deadline": { "type": "number" },
            "compositionTheme": { "type": "string", "enum": ["dark", "sepia", "green", "custom"] },
            "paperWidth": { "type": "number" },
            "backgroundOpacity": { "type": "number" }
          },
          "required": ["targetWordCount", "sessionTarget", "compositionTheme", "paperWidth", "backgroundOpacity"]
        }
      },
      "required": ["id", "name", "ownerId", "createdAt", "updatedAt", "settings"]
    },
    "Doc": {
      "title": "Document",
      "description": "A document within a project (text, folder, etc.).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "folder", "research", "trash", "front-matter", "characters", "places"] },
        "parentId": { "type": "string" },
        "order": { "type": "number" },
        "metadata": {
          "type": "object",
          "properties": {
            "status": { "type": "string" },
            "label": { "type": "string" },
            "labelColor": { "type": "string" },
            "synopsis": { "type": "string" },
            "notes": { "type": "string" },
            "targetWordCount": { "type": "number" },
            "isIncludeInCompile": { "type": "boolean" },
            "sectionType": { "type": "string" },
            "createdAt": { "type": "number" },
            "updatedAt": { "type": "number" },
            "keywords": { "type": "array", "items": { "type": "string" } },
            "customMetadata": { "type": "object" },
            "snapshots": { "type": "array", "items": { "type": "object" } },
            "comments": { "type": "array", "items": { "type": "object" } },
            "bookmarks": { "type": "array", "items": { "type": "object" } }
          },
          "required": ["status", "label", "labelColor", "synopsis", "notes", "targetWordCount", "isIncludeInCompile", "sectionType", "createdAt", "updatedAt"]
        }
      },
      "required": ["id", "title", "content", "type", "order", "metadata"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Root collection for projects."
    },
    "/projects/{projectId}/docs/{docId}": {
      "schema": "Doc",
      "description": "Documents belonging to a project."
    }
  }
}
